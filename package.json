{
  "name": "lf-automatizador",
  "productName": "LF Automatizador",
  "version": "0.9.9",
  "description": "Software de Automatizacion de Radio",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --publish never",
    "dist:win": "electron-builder --win nsis --publish never",
    "dist:linux": "electron-builder --linux AppImage deb --publish never"
  },
  "author": "Luis Fernando",
  "license": "ISC",
  "devDependencies": {
    "@electron/rebuild": "^4.0.4",
    "electron": "^41.7.0",
    "electron-builder": "^25.1.8"
  },
  "dependencies": {
    "better-sqlite3": "^12.10.0",
    "ffmpeg-static": "^5.3.0",
    "fuse.js": "^7.3.0",
    "node-id3": "^0.2.9"
  },
  "engines": {
    "node": ">=22.12.0"
  },
  "build": {
    "appId": "com.lfautomatizador.app",
    "productName": "LF Automatizador",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "database.js",
      "backend/**/*",
      "frontend/**/*",
      "assets/**/*",
      "Documentación/**/*",
      "bin/**/*",
      "icon.ico",
      "icon.png",
      "package.json"
    ],
    "asarUnpack": [
      "node_modules/ffmpeg-static/**/*",
      "node_modules/better-sqlite3/**/*",
      "bin/**/*"
    ],
    "extraResources": [
      {
        "from": "bin",
        "to": "bin",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "build/vcredist",
        "to": "vcredist",
        "filter": [
          "*.exe"
        ]
      }
    ],
    "artifactName": "LF-Automatizador-${version}-${os}-${arch}.${ext}",
    "win": {
      "target": "nsis",
      "icon": "icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "include": "build/installer.nsh"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "AudioVideo",
      "icon": "icon.png",
      "executableName": "lf-automatizador",
      "maintainer": "Luis Fernando"
    },
    "deb": {
      "depends": [
        "libasound2 | libasound2t64",
        "libgtk-3-0 | libgtk-3-0t64",
        "libnss3",
        "libxss1",
        "libxtst6",
        "libnotify4",
        "libayatana-appindicator3-1 | libappindicator3-1",
        "xdg-utils"
      ]
    }
  }
}
